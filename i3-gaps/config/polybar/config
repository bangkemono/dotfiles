format-full-prefix = "ÔČÄ  "
format-full-prefix-foreground = ${colors.foreground-dark}
format-full-underline = ${self.format-charging-underline}

ramp-capacity-0 = Óą∂
ramp-capacity-1 = Óą∑
ramp-capacity-2 = Óął
